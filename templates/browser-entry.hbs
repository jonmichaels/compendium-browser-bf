<li class="item" data-entry-uuid="{{ entry.uuid }}" draggable="true">

    <div class="item-row">

        <div class="item-name rollable" role="button" data-action="openLink">

            {{#if entry.img}}
            <img class="item-image gold-icon" loading="lazy" src="{{ entry.img }}"
                 alt="{{ entry.name }}" draggable="false">
            {{/if}}

            <div class="name">
                <span class="title">{{ entry.name }}</span>
            </div>

        </div>

        <div class="item-detail item-source {{#unless entry.source}}empty{{/unless}}">
            {{#if entry.source}}
            <span class="condensed">{{ entry.source }}</span>
            {{/if}}
        </div>

        <div class="item-detail item-controls">

            {{#if displaySelection}}
            <input type="checkbox" name="selected" value="{{ entry.uuid }}"
                   {{ checked selected }}>
            {{/if}}

        </div>

    </div>

</li>
