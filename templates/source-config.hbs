<section class="packs">
    {{#if packs.items.entries.length}}
    <fieldset class="card packs-section">
        <legend>{{ localize "DOCUMENT.Items" }}</legend>
        <menu class="packs-list unlist items">
            {{#if packs.items.showAll}}
            <li class="all">
                <label class="checkbox">
                    <input type="checkbox" name="all-items"
                           {{ checked packs.items.checked }}
                           data-type="pack"
                           {{#if packs.items.indeterminate}}data-indeterminate="true"{{/if}}>
                    <span class="title">{{ localize "all" }}</span>
                </label>
            </li>
            {{/if}}
            {{#each packs.items.entries}}
            <li>
                <label class="checkbox">
                    <input type="checkbox" name="{{ id }}"
                           {{ checked checked }}
                           data-type="pack">
                    <span class="title">{{ title }}</span>
                    {{#if tag}}<span class="tag">{{ tag }}</span>{{/if}}
                </label>
            </li>
            {{/each}}
        </menu>
    </fieldset>
    {{/if}}

    {{#if packs.actors.entries.length}}
    <fieldset class="card packs-section">
        <legend>{{ localize "DOCUMENT.Actors" }}</legend>
        <menu class="packs-list unlist actors">
            {{#if packs.actors.showAll}}
            <li class="all">
                <label class="checkbox">
                    <input type="checkbox" name="all-actors"
                           {{ checked packs.actors.checked }}
                           data-type="pack"
                           {{#if packs.actors.indeterminate}}data-indeterminate="true"{{/if}}>
                    <span class="title">{{ localize "all" }}</span>
                </label>
            </li>
            {{/if}}
            {{#each packs.actors.entries}}
            <li>
                <label class="checkbox">
                    <input type="checkbox" name="{{ id }}"
                           {{ checked checked }}
                           data-type="pack">
                    <span class="title">{{ title }}</span>
                    {{#if tag}}<span class="tag">{{ tag }}</span>{{/if}}
                </label>
            </li>
            {{/each}}
        </menu>
    </fieldset>
    {{/if}}
</section>
