<div>
    <div class="mode-toggle">
        {{#if showModeToggle}}
        <slide-toggle class="mode-slider header-control" data-action="toggleMode"
                      {{ checked isAdvanced }}
                      id="{{ partId }}-mode-toggle"></slide-toggle>
        <label for="{{ partId }}-mode-toggle">{{ localize "compendium-browser-bf.Mode.Advanced" }}</label>
        {{/if}}
    </div>
    <button type="button" class="configure-sources" data-action="configureSources">
        <i class="fas fa-cog"></i> {{ localize "compendium-browser-bf.ConfigureSources" }}
    </button>
</div>
