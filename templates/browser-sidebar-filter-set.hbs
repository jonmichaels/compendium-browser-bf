<div class="filter filter-set collapsible {{~#if (eq expanded false)}} collapsed{{/if}}"
     data-filter-id="{{ key }}">
    <div class="filter-header">
        <label data-action="toggleCollapsed">
            <span class="roboto-upper">{{ localize label }}</span>
            <i class="fa-solid fa-caret-down" inert></i>
        </label>
    </div>
    <div class="collapsible-content">
        <div class="wrapper">
            {{~#if config.blank}}
            <span class="filter-choice">
                <input type="checkbox" name="additional.{{ key }}._blank"
                       id="{{ @root.partId }}-additional-{{ key }}-_blank"
                       value="1" {{ checked value._blank }} {{ disabled locked._blank }}>
                <label for="{{ @root.partId }}-additional-{{ key }}-_blank">{{ localize config.blank }}</label>
            </span>
            {{/if~}}
            {{~#each config.choices}}
            <span class="filter-choice">
                <input type="checkbox" name="additional.{{ ../key }}.{{ @key }}"
                       id="{{ @root.partId }}-additional-{{ ../key }}-{{ @key }}"
                       value="1" {{ checked (lookup ../value @key) }}
                       {{ disabled (lookup ../locked @key) }}>
                <label for="{{ @root.partId }}-additional-{{ ../key }}-{{ @key }}">{{ localize (ifThen label label this) }}</label>
            </span>
            {{/each~}}
        </div>
    </div>
</div>
